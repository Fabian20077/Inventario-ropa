{
  "compilerOptions": {
    "module": "ESNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "target": "ES2022",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": ".",
    
   
    "baseUrl": ".",
    "paths": {
   
      "@shared/*": ["shared/*"]
    }
  },
  "include": [
    "server/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}